<Window x:Class="AplicatieWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Masina" Height="350" Width="400">

    <Grid Margin="10">
        <StackPanel>

            <TextBlock Text="Detalii Masina"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Model}"/>
            <TextBlock Text="{Binding AnFabricatie}"/>
            <TextBlock Text="{Binding TipMotorizare}"/>
            <TextBlock Text="{Binding Pret}"/>
            <TextBlock Text="{Binding CuloareMasina}"/>
            <TextBlock Text="{Binding Model}" FontSize="25" Foreground="Red"/>

        </StackPanel>
    </Grid>
</Window>