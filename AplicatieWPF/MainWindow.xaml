<Window x:Class="AplicatieWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Masini" Height="500" Width="500">

    <StackPanel Margin="10">

        <Button Content="Lista masini"
                Height="30"
                Click="BtnListaMasini_Click"/>

        <ListBox x:Name="ListaMasini"
                 Height="200"
                 Margin="0,10,0,10"/>

        <TextBox x:Name="TxtIndex" Height="25"/>

        <Button Content="Afiseaza detalii"
                Height="30"
                Margin="0,10,0,10"
                Click="BtnDetalii_Click"/>

        <TextBlock x:Name="TxtDetalii"
                   TextWrapping="Wrap"/>

    </StackPanel>
</Window>